# Declarant Portal — local env template.
#
#   cp .env.example .env
#   echo "RECOR_DB_PASSWORD=$(openssl rand -hex 24)" >> .env

RECOR_DB_PASSWORD=

# ─── Vault (OPS-4) ──────────────────────────────────────────────────
#
# OPTIONAL in dev; REQUIRED in production.
#
# The portal is a static SPA + nginx; its Vault subtree is
# `secret/recor/portal/*` (CSP_CONNECT_SRC, OIDC_CLIENT_ID, etc.).
# When VAULT_ADDR is set, docker-entrypoint.sh can be extended to
# fetch these values from Vault before invoking envsubst on the
# nginx templates (TODO follow-up; today these still come from env).
#
# Issue the role-id/secret-id pair via:
#   bash infrastructure/vault/scripts/init-dev-vault.sh
#
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=
