# recor-verification-engine — local development env template.
# Copy to .env (gitignored) and set values.
#
#   cp .env.example .env
#   echo "RECOR_DB_PASSWORD=$(openssl rand -base64 24)" >> .env

RECOR_DB_PASSWORD=

# ─── Vault (OPS-4) ──────────────────────────────────────────────────
#
# OPTIONAL in dev; REQUIRED in production.
#
# When VAULT_ADDR is set, the V-engine logs in via AppRole at startup
# and pulls DATABASE_URL, INBOUND_HMAC_SECRET, WRITEBACK_HMAC_SECRET,
# OIDC_*, and LOG_REDACTION_KEY from
# `secret/recor/verification-engine/*`. The AppRole pair below is the
# ONLY secret material that lives in env (D18).
#
# When VAULT_ADDR is empty, the V-engine falls back to env-only and
# emits a startup `warn!`. Production deployments MUST set VAULT_ADDR.
#
# Issue the role-id/secret-id pair via:
#   bash infrastructure/vault/scripts/init-dev-vault.sh
#
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=
