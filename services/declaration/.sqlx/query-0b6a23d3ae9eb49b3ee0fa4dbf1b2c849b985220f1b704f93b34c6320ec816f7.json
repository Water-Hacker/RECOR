  "query": "\n            SELECT id, event_id, event_type, event_version, aggregate_id, payload, dispatch_attempts\n            FROM outbox\n            WHERE dispatched_at IS NULL\n              AND dispatch_attempts < $1\n            ORDER BY created_at ASC\n            LIMIT 32\n            ",
