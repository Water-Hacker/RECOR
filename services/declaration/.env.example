# recor-declaration — local development env template.
#
# Copy to .env and set values. .env is gitignored.
#
#   cp .env.example .env
#   echo "RECOR_DB_PASSWORD=$(openssl rand -base64 24)" >> .env

# Postgres password used by docker-compose for the local Postgres instance.
# REQUIRED — the compose stack fails to start if unset.
RECOR_DB_PASSWORD=

# Optional: override the base URL embedded in receipt-URL responses.
# RECOR_BASE_URL=http://localhost:8080

# ─── Vault (OPS-4) ──────────────────────────────────────────────────
#
# OPTIONAL in dev; REQUIRED in production.
#
# When VAULT_ADDR is set, the service logs in via AppRole at startup
# and pulls DATABASE_URL, RELAY_HMAC_SECRET, WRITEBACK_HMAC_SECRET,
# OIDC_*, and LOG_REDACTION_KEY from
# `secret/recor/declaration/*`. The AppRole pair below is the ONLY
# secret material that lives in env (D18); everything else comes from
# Vault.
#
# When VAULT_ADDR is empty, the service falls back to env-only secret
# loading and emits a startup `warn!`. Production deployments MUST
# set VAULT_ADDR or the configuration is non-compliant with D18.
#
# Issue the role-id/secret-id pair via:
#   bash infrastructure/vault/scripts/init-dev-vault.sh
#
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=
