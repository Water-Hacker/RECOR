# recor-declaration — local development env template.
#
# Copy to .env and set values. .env is gitignored.
#
#   cp .env.example .env
#   echo "RECOR_DB_PASSWORD=$(openssl rand -base64 24)" >> .env

# Postgres password used by docker-compose for the local Postgres instance.
# REQUIRED — the compose stack fails to start if unset.
RECOR_DB_PASSWORD=

# Optional: override the base URL embedded in receipt-URL responses.
# RECOR_BASE_URL=http://localhost:8080
