{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "OBS-1: platform-wide HTTP health for the RÉCOR services. Request rates, 5xx-error ratio, p50/p99 latencies, service up status. The four panels together answer the question 'is the platform serving traffic right now?'",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
      "description": "Service up status, per scrape target.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
          "expr": "up{job=~\"recor-.*\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Service up status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
      "description": "Request rate per service, smoothed over 1m.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
          "expr": "sum by (job) (rate(http_requests_total{job=~\"recor-.*\"}[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
      "description": "5xx error ratio (5xx responses / all responses), per service. The RecorHttp5xxRateHigh alert fires when this exceeds 5% for 10 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "ratio",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
          "expr": "sum by (job) (rate(http_requests_total{job=~\"recor-.*\",status=~\"5..\"}[5m])) / sum by (job) (rate(http_requests_total{job=~\"recor-.*\"}[5m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "5xx error ratio",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
      "description": "p99 HTTP request latency by service.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, job) (rate(http_request_duration_seconds_bucket{job=~\"recor-.*\"}[5m])))",
          "legendFormat": "{{job}} p99",
          "refId": "A"
        }
      ],
      "title": "p99 HTTP latency by service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
      "description": "p99 latency broken down by endpoint (matched path template). Use this to identify slow endpoints.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, path, job) (rate(http_request_duration_seconds_bucket{job=~\"recor-.*\"}[5m])))",
          "legendFormat": "{{job}} {{path}}",
          "refId": "A"
        }
      ],
      "title": "p99 latency by endpoint",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
      "description": "Declarations submitted by kind. Increments only after successful persistence.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "submits/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "recor-prometheus" },
          "expr": "sum by (kind) (rate(recor_declarations_submitted_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "title": "Declaration submit rate by kind",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["recor", "obs-1", "platform-health"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RÉCOR — Platform Health",
  "uid": "recor-platform-health",
  "version": 1,
  "weekStart": ""
}
