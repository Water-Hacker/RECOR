# RÉCOR dev observability stack — environment file template.
#
# Copy to .env (which is gitignored) and set per-developer values.
#
#   cp .env.example .env
#   ${EDITOR:-vi} .env
#
# Per D18 there is NO password committed to the repository. The compose
# stack fail-closes if RECOR_GRAFANA_ADMIN_PASSWORD is unset. To generate
# a per-developer random password:
#
#   echo "RECOR_GRAFANA_ADMIN_PASSWORD=$(openssl rand -base64 24)" >> .env
#
# This is a DEV stack. The password protects only your local Grafana on
# 127.0.0.1:3000 and does not need to be rotated. Treating it casually
# does not violate D18 because the artefact is not committed.

# Grafana admin login. Default username "recor-admin"; password REQUIRED.
RECOR_GRAFANA_ADMIN_USER=recor-admin
RECOR_GRAFANA_ADMIN_PASSWORD=
