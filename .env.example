# RÉCOR — repository-root env template.
#
# This file is read by docker-compose stacks that bring up dev
# infrastructure (currently: infrastructure/vault/docker-compose.yaml).
# Per-service env templates live in their respective directories:
#
#   services/declaration/.env.example
#   services/verification-engine/.env.example
#   applications/declarant-portal/.env.example
#
# Copy to .env (gitignored), tweak, and load:
#
#   cp .env.example .env
#
# ─── Vault (OPS-4) ──────────────────────────────────────────────────
#
# Dev-only Vault root token. The dev-mode Vault is brought up with
# `-dev-root-token-id=${VAULT_DEV_ROOT_TOKEN_ID}` so every developer's
# bootstrap script produces identical state (D19 reproducibility).
#
# THIS TOKEN IS NEVER USED IN PRODUCTION. The production Vault is
# initialised via the Shamir / auto-unseal flow; the initial root
# token is destroyed after the admin AppRole is created.
#
# Why a hard-coded value rather than a per-developer random:
#   - integration-smoke tests run the same script and need a known
#     token to log in.
#   - rotating this token only matters if dev Vault is exposed beyond
#     127.0.0.1, which the compose file explicitly forbids.
#
# D17: the dev Vault container is bound to 127.0.0.1 only. If you find
# yourself wanting to expose it on the LAN, you are doing something
# wrong — use the staging Vault cluster instead.
VAULT_DEV_ROOT_TOKEN_ID=recor-dev-root-token
